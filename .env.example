# === Управление прайсом и услугами через Google Таблицу ===
# Если переменные не заданы — сайт работает на данных из кода (как есть).
#
# Вариант 1 (рекомендуется): ID таблицы.
# ID из URL: https://docs.google.com/spreadsheets/d/<ВОТ_ЭТОТ_ID>/edit
# Таблицу открыть на чтение: «Поделиться → Доступ по ссылке → Читатель».
GOOGLE_SHEET_ID=
# (необязательно) имена вкладок, по умолчанию «Услуги» и «Прайс»
# GOOGLE_SHEET_SERVICES_TAB=Услуги
# GOOGLE_SHEET_PRICES_TAB=Прайс
#
# Вариант 2: прямые CSV-ссылки («Файл → Поделиться → Опубликовать в интернете → CSV»).
# GOOGLE_SHEET_SERVICES_URL=
# GOOGLE_SHEET_PRICES_URL=
#
# Как часто перечитывать таблицу, сек (по умолчанию 300).
# GOOGLE_SHEET_REVALIDATE=300
